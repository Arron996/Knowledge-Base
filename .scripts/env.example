# Secrets for launchd (NOT committed). Pick one:
#
# Option A — dedicated file (recommended for launchd):
#   mkdir -p ~/.config/kb-automation
#   echo 'cursor_...' > ~/.config/kb-automation/cursor_api_key
#   chmod 600 ~/.config/kb-automation/cursor_api_key
#
# Option B — ~/.zshrc.local (interactive shell):
#   export CURSOR_API_KEY="cursor_..."
#
# Then inject into evening LaunchAgent (local plist only, not in git):
#   bash .scripts/install-launchd.sh
