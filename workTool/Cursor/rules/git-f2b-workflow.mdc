## 五、一键脚本参考（zsh，替换 `<FEATURE_BRANCH>`）

```zsh
branch="feature/20250128_adminOptimization"  # 改为实际分支名

f2b_merge() {
  local repo="$1"
  local worktree="$2"
  local base="$3"
  local local_branch="$4"
  local feature="$5"
  local use_direct_base="${6:-false}"

  cd "$repo" || return 1
  git push origin "$feature"
  git fetch origin
  if [[ ! -d "$worktree" ]]; then
    if [[ "$use_direct_base" == "true" ]]; then
      git worktree add "$worktree" "origin/$base"
    else
      git worktree add -b "$local_branch" "$worktree" "origin/$base"
    fi
  fi

  cd "$worktree" || return 1
  git rev-parse --show-toplevel; git branch --show-current; git status --short --branch
  git fetch origin; git pull origin "$base"
  git branch --show-current; git status --short --branch
  git merge "origin/$feature"
  git branch --show-current; git status --short --branch
  git push origin "HEAD:$base"
}

