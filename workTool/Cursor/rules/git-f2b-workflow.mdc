worktree="/Users/aaron/IdeaProjects/gds-order-admin-fe-f2b-base"
base="develop/base"
local_branch="f2b-admin-fe-base"
if [[ ! -d "$worktree" ]]; then cd "$repo"; git fetch origin; git worktree add -b "$local_branch" "$worktree" "origin/$base"; fi
cd "$worktree"
git rev-parse --show-toplevel; git branch --show-current; git status --short --branch
git fetch origin; git pull origin "$base"

